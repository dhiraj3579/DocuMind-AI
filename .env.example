# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# CUSTOM_GEMINI_API_KEY: Optional custom API key for Gemini.
# If not provided, the app will use the default GEMINI_API_KEY.
CUSTOM_GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL=
